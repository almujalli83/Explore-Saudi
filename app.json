{
  "expo": {
    "name": "Explore Saudi",
    "slug": "explore-saudi",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "exploresaudi",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1A1A2E",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.exploresaudi.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1A1A2E"
      },
      "package": "com.exploresaudi.app"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "expo-image",
        { "allowBackgroundRemoval": false }
      ]
    ]
  }
}
